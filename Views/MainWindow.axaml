<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:v="using:TwitchChatCore.Views"
        xmlns:s="using:TwitchChatCore.Server"
        xmlns:models="using:TwitchChatCore.Core.Models"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="TwitchChatCore.Views.MainWindow"
        Title="{DynamicResource MainWindowTitle}"
        Width="1150" Height="750" MinWidth="800" MinHeight="500"
        Background="#0F172A"
        RequestedThemeVariant="Dark"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterScreen"
        Icon="avares://TwitchChatCore/Assets/app_main.png">
    <Grid>
        <Grid ColumnDefinitions="420, *" Margin="0, 30, 0, 0">
            <!-- Settings Panel -->
            <Border Grid.Column="0" Background="#1E293B" CornerRadius="0,16,16,0" Padding="24,24,4,24">
                <Grid RowDefinitions="Auto, *">
                    <!-- Emotes Download Progress -->
                    <Border Grid.Row="0" Name="EmoteProgressPanel" Background="#1E293B" Padding="16" CornerRadius="12" Margin="0,0,20,16" IsVisible="False" BorderBrush="#334155" BorderThickness="1" BoxShadow="0 4 6 0 #30000000">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Name="EmoteProgressText" Grid.Column="0" Text="Downloading 7TV Emotes" Foreground="#E2E8F0" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,12,0" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Name="EmoteSpeedText" Text="0.0 em/s" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center" />
                                    <Button Name="RetryEmotesButton" Content="Retry" Click="RetryEmotes_Click" IsVisible="False" Padding="12,6" FontSize="12" FontWeight="Bold" Background="#EF4444" Foreground="#FFFFFF" CornerRadius="6" VerticalAlignment="Center" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                            <ProgressBar Name="EmoteProgressBar" Minimum="0" Maximum="100" Value="0" Height="8" CornerRadius="4" Foreground="#3B82F6" Background="#0F172A" />
                            <TextBlock Name="EmoteErrorText" Text="" Foreground="#F87171" FontSize="12" TextWrapping="Wrap" IsVisible="False"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" Margin="0,0,-8,0" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="16" Margin="0,0,16,0">
                            <Grid>
                                <TextBlock Text="{DynamicResource DesignStudio}" FontSize="24" FontWeight="Bold" Foreground="#FFFFFF" />
                                <Button HorizontalAlignment="Right" Background="Transparent" Foreground="#94A3B8" Click="OpenSettings_Click" Padding="8,4" Cursor="Hand">
                                    <PathIcon Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.43-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" Width="20" Height="20" Foreground="#94A3B8"/>
                                </Button>
                            </Grid>
                            <!-- 🌟 Главные настройки -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,5,0,5">
                                <PathIcon Data="M12,2 L15.09,8.26 L22,9.27 L17,14.14 L18.18,21.02 L12,17.77 L5.82,21.02 L7,14.14 L2,9.27 L8.91,8.26 L12,2 Z" Width="16" Height="16" Foreground="#38BDF8"/>
                                <TextBlock Text="{DynamicResource CategoryMain}" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Spacing="10" Margin="0,0,0,10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{DynamicResource PresetLabel}" FontSize="12" Foreground="#94A3B8"/>
                                    <ComboBox Name="ThemeComboBox" HorizontalAlignment="Stretch" SelectionChanged="DesignComboBox_Changed">
                                        <ComboBoxItem Content="{DynamicResource ThemeGlass}"/>
                                        <ComboBoxItem Content="{DynamicResource ThemeCyberpunk}"/>
                                        <ComboBoxItem Content="{DynamicResource ThemeMinimalism}"/>
                                        <ComboBoxItem Content="{DynamicResource ThemeRetro}"/>
                                        <ComboBoxItem Content="{DynamicResource ThemeCustom}"/>
                                    </ComboBox>
                                </StackPanel>
                                <Grid ColumnDefinitions="*, *">
                                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,10,0">
                                        <TextBlock Text="{DynamicResource FontLabel}" FontSize="12" Foreground="#94A3B8"/>
                                        <ComboBox Name="FontComboBox" HorizontalAlignment="Stretch" SelectionChanged="DesignComboBox_Changed">
                                            <ComboBoxItem FontFamily="Outfit" Content="Outfit - Aa Bb Cc"/>
                                            <ComboBoxItem FontFamily="Roboto" Content="Roboto - Aa Bb Cc"/>
                                            <ComboBoxItem FontFamily="Courier New" Content="Courier New - Aa Bb Cc"/>
                                            <ComboBoxItem FontFamily="Comic Sans MS" Content="Comic Sans - Aa Bb Cc"/>
                                            <ComboBoxItem FontFamily="Impact" Content="Impact - Aa Bb Cc"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="{DynamicResource GlobalBgColorLabel}" FontSize="12" Foreground="#94A3B8"/>
                                        <ColorPicker Name="GlobalBgColorPicker" HorizontalAlignment="Stretch" ColorChanged="TextColorPicker_ColorChanged" IsAlphaEnabled="True" ColorSpectrumShape="Ring" />
                                    </StackPanel>
                                </Grid>
                                
                                <!-- Custom Presets -->
                                <StackPanel Spacing="4" Margin="0,5,0,0">
                                    <TextBlock Text="{DynamicResource CustomPresetsLabel}" FontSize="12" Foreground="#94A3B8"/>
                                    <StackPanel Spacing="8">
                                        <!-- Слот 1 -->
                                        <Grid ColumnDefinitions="*, Auto, Auto, Auto">
                                            <TextBox Name="Preset1NameBox" Grid.Column="0" Margin="0,0,5,0" Watermark="{DynamicResource CustomPreset1Placeholder}"/>
                                            <Button Name="SavePreset1Btn" ToolTip.Tip="Сохранить" Grid.Column="1" Margin="0,0,5,0" Click="SavePreset_Click" Tag="0" Padding="6">
                                                <PathIcon Data="M17,3H5C3.89,3,3,3.9,3,5V19C3,20.1,3.89,21,5,21H19C20.1,21,21,20.1,21,19V7L17,3Z M12,19C10.34,19,9,17.66,9,16C9,14.34,10.34,13,12,13C13.66,13,15,14.34,15,16C15,17.66,13.66,19,12,19Z M15,9H5V5H15V9Z" Width="14" Height="14" Foreground="#94A3B8"/>
                                            </Button>
                                            <Button Name="LoadPreset1Btn" ToolTip.Tip="Загрузить" Grid.Column="2" Margin="0,0,5,0" Click="LoadPreset_Click" Tag="0" Padding="6">
                                                <PathIcon Data="M20,6H12L10,4H4C2.9,4,2,4.9,2,6V18C2,19.1,2.9,20,4,20H20C21.1,20,22,19.1,22,18V8C22,6.9,21.1,6,20,6Z" Width="14" Height="14" Foreground="#94A3B8"/>
                                            </Button>
                                            <Button Name="ExportPreset1Btn" ToolTip.Tip="Скачать" Grid.Column="3" Click="ExportPreset_Click" Tag="0" Padding="6">
                                                <PathIcon Data="M19,9H15V3H9V9H5L12,16L19,9Z M5,18V20H19V18H5Z" Width="14" Height="14" Foreground="#94A3B8"/>
                                            </Button>
                                        </Grid>
                                        <!-- Слот 2 -->
                                        <Grid ColumnDefinitions="*, Auto, Auto, Auto">
                                            <TextBox Name="Preset2NameBox" Grid.Column="0" Margin="0,0,5,0" Watermark="{DynamicResource CustomPreset2Placeholder}"/>
                                            <Button Name="SavePreset2Btn" ToolTip.Tip="Сохранить" Grid.Column="1" Margin="0,0,5,0" Click="SavePreset_Click" Tag="1" Padding="6">
                                                <PathIcon Data="M17,3H5C3.89,3,3,3.9,3,5V19C3,20.1,3.89,21,5,21H19C20.1,21,21,20.1,21,19V7L17,3Z M12,19C10.34,19,9,17.66,9,16C9,14.34,10.34,13,12,13C13.66,13,15,14.34,15,16C15,17.66,13.66,19,12,19Z M15,9H5V5H15V9Z" Width="14" Height="14" Foreground="#94A3B8"/>
                                            </Button>
                                            <Button Name="LoadPreset2Btn" ToolTip.Tip="Загрузить" Grid.Column="2" Margin="0,0,5,0" Click="LoadPreset_Click" Tag="1" Padding="6">
                                                <PathIcon Data="M20,6H12L10,4H4C2.9,4,2,4.9,2,6V18C2,19.1,2.9,20,4,20H20C21.1,20,22,19.1,22,18V8C22,6.9,21.1,6,20,6Z" Width="14" Height="14" Foreground="#94A3B8"/>
                                            </Button>
                                            <Button Name="ExportPreset2Btn" ToolTip.Tip="Скачать" Grid.Column="3" Click="ExportPreset_Click" Tag="1" Padding="6">
                                                <PathIcon Data="M19,9H15V3H9V9H5L12,16L19,9Z M5,18V20H19V18H5Z" Width="14" Height="14" Foreground="#94A3B8"/>
                                            </Button>
                                        </Grid>
                                        <!-- Слот 3 -->
                                        <Grid ColumnDefinitions="*, Auto, Auto, Auto">
                                            <TextBox Name="Preset3NameBox" Grid.Column="0" Margin="0,0,5,0" Watermark="{DynamicResource CustomPreset3Placeholder}"/>
                                            <Button Name="SavePreset3Btn" ToolTip.Tip="Сохранить" Grid.Column="1" Margin="0,0,5,0" Click="SavePreset_Click" Tag="2" Padding="6">
                                                <PathIcon Data="M17,3H5C3.89,3,3,3.9,3,5V19C3,20.1,3.89,21,5,21H19C20.1,21,21,20.1,21,19V7L17,3Z M12,19C10.34,19,9,17.66,9,16C9,14.34,10.34,13,12,13C13.66,13,15,14.34,15,16C15,17.66,13.66,19,12,19Z M15,9H5V5H15V9Z" Width="14" Height="14" Foreground="#94A3B8"/>
                                            </Button>
                                            <Button Name="LoadPreset3Btn" ToolTip.Tip="Загрузить" Grid.Column="2" Margin="0,0,5,0" Click="LoadPreset_Click" Tag="2" Padding="6">
                                                <PathIcon Data="M20,6H12L10,4H4C2.9,4,2,4.9,2,6V18C2,19.1,2.9,20,4,20H20C21.1,20,22,19.1,22,18V8C22,6.9,21.1,6,20,6Z" Width="14" Height="14" Foreground="#94A3B8"/>
                                            </Button>
                                            <Button Name="ExportPreset3Btn" ToolTip.Tip="Скачать" Grid.Column="3" Click="ExportPreset_Click" Tag="2" Padding="6">
                                                <PathIcon Data="M19,9H15V3H9V9H5L12,16L19,9Z M5,18V20H19V18H5Z" Width="14" Height="14" Foreground="#94A3B8"/>
                                            </Button>
                                        </Grid>
                                        <TextBlock Name="ExportStatusText" Text="" Foreground="#10B981" FontSize="11" TextWrapping="Wrap" HorizontalAlignment="Center" IsVisible="False" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <Separator Background="#334155" Margin="0,5" Height="1"/>

                            <!-- 💬 Внешний вид сообщений -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,5,0,5">
                                <PathIcon Data="M20,2H4C2.9,2,2,2.9,2,4v18l4-4h14c1.1,0,2-0.9,2-2V4C22,2.9,21.1,2,20,2z" Width="16" Height="16" Foreground="#38BDF8"/>
                                <TextBlock Text="{DynamicResource CategoryMessageVisuals}" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Spacing="10" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,0,10,10">
                                        <TextBlock Text="{DynamicResource BorderStyleLabel}" FontSize="12" Foreground="#94A3B8"/>
                                        <ComboBox Name="BorderStyleComboBox" HorizontalAlignment="Stretch" SelectionChanged="DesignComboBox_Changed">
                                            <ComboBoxItem Content="{DynamicResource BorderGlass}"/>
                                            <ComboBoxItem Content="{DynamicResource BorderNeon}"/>
                                            <ComboBoxItem Content="{DynamicResource BorderSolid}"/>
                                            <ComboBoxItem Content="{DynamicResource BorderNone}"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="0,0,0,10">
                                        <TextBlock Text="{DynamicResource ShapeLabel}" FontSize="12" Foreground="#94A3B8"/>
                                        <ComboBox Name="ShapeComboBox" HorizontalAlignment="Stretch" SelectionChanged="DesignComboBox_Changed">
                                            <ComboBoxItem Content="{DynamicResource ShapeSquare}"/>
                                            <ComboBoxItem Content="{DynamicResource ShapeRound}"/>
                                            <ComboBoxItem Content="{DynamicResource ShapeTail}"/>
                                            <ComboBoxItem Content="{DynamicResource ShapeNoBorder}"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,0,10,0">
                                        <TextBlock Text="{DynamicResource LayoutLabel}" FontSize="12" Foreground="#94A3B8"/>
                                        <ComboBox Name="LayoutComboBox" HorizontalAlignment="Stretch" SelectionChanged="DesignComboBox_Changed">
                                            <ComboBoxItem Content="{DynamicResource LayoutInline}"/>
                                            <ComboBoxItem Content="{DynamicResource LayoutNickAbove}"/>
                                            <ComboBoxItem Content="{DynamicResource LayoutColumns}"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="0,0,0,0">
                                        <TextBlock Text="{DynamicResource AnimationLabel}" FontSize="12" Foreground="#94A3B8"/>
                                        <ComboBox Name="AnimationComboBox" HorizontalAlignment="Stretch" SelectionChanged="DesignComboBox_Changed">
                                            <ComboBoxItem Content="{DynamicResource AnimationPop}"/>
                                            <ComboBoxItem Content="{DynamicResource AnimationSlide}"/>
                                            <ComboBoxItem Content="{DynamicResource AnimationFade}"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                                
                                <StackPanel Spacing="6" Margin="0,5,0,0">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource MessageSpacingLabel}" FontSize="13" Foreground="#E2E8F0"/>
                                        <TextBlock Name="SpacingValText" Text="4px" HorizontalAlignment="Right" Foreground="#94A3B8" FontSize="12"/>
                                    </Grid>
                                    <Slider Name="SpacingSlider" Minimum="0" Maximum="24" Value="4" TickFrequency="1" IsSnapToTickEnabled="True" PropertyChanged="DesignSlider_PropertyChanged" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource GlassOpacityLabel}" FontSize="13" Foreground="#E2E8F0"/>
                                        <TextBlock Name="OpacityValText" Text="45%" HorizontalAlignment="Right" Foreground="#94A3B8" FontSize="12"/>
                                    </Grid>
                                    <Slider Name="OpacitySlider" Minimum="0" Maximum="100" Value="45" TickFrequency="1" IsSnapToTickEnabled="True" PropertyChanged="DesignSlider_PropertyChanged" />
                                </StackPanel>
                            </StackPanel>

                            <Separator Background="#334155" Margin="0,5" Height="1"/>

                            <!-- 🎨 Цвета -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,5,0,5">
                                <PathIcon Data="M12,22C6.49,22,2,17.51,2,12S6.49,2,12,2s10,4.49,10,10c0,1.38-1.12,2.5-2.5,2.5h-1.89c-0.31,0-0.59,0.13-0.8,0.33l-0.1,0.1 C16.51,15.13,16.29,15.28,16,15.28c-0.83,0-1.5-0.67-1.5-1.5V13c0-1.66-1.34-3-3-3h-2c-1.66,0-3,1.34-3,3s1.34,3,3,3h4.5 c1.66,0,3,1.34,3,3s-1.34,3-3,3H12z M6.5,10C7.33,10,8,9.33,8,8.5S7.33,7,6.5,7S5,7.67,5,8.5S5.67,10,6.5,10z M9.5,6C10.33,6,11,5.33,11,4.5S10.33,3,9.5,3S8,3.67,8,4.5S8.67,6,9.5,6z M14.5,6C15.33,6,16,5.33,16,4.5S15.33,3,14.5,3S13,3.67,13,4.5S13.67,6,14.5,6z M17.5,10c0.83,0,1.5-0.67,1.5-1.5S18.33,7,17.5,7S16,7.67,16,8.5S16.67,10,17.5,10z" Width="16" Height="16" Foreground="#38BDF8"/>
                                <TextBlock Text="{DynamicResource CategoryColors}" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Spacing="6" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,*,*,*,*" RowDefinitions="Auto, Auto">
                                    <!-- Подписи -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource MessageBgColorLabel}" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{DynamicResource TextColorLabel}" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource ColorBroadcasterLabel}" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{DynamicResource ColorModLabel}" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="{DynamicResource ColorVipLabel}" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                    
                                    <!-- Выбор цвета -->
                                    <ColorPicker Grid.Row="1" Grid.Column="0" Name="MessageBgColorPicker" ToolTip.Tip="Message Background" ColorChanged="TextColorPicker_ColorChanged" HorizontalAlignment="Center" IsAlphaEnabled="False" ColorSpectrumShape="Ring" />
                                    <ColorPicker Grid.Row="1" Grid.Column="1" Name="TextColorPicker" ToolTip.Tip="Text Color" ColorChanged="TextColorPicker_ColorChanged" HorizontalAlignment="Center" IsAlphaEnabled="False" ColorSpectrumShape="Ring" />
                                    <ColorPicker Grid.Row="1" Grid.Column="2" Name="BroadcasterColorPicker" ToolTip.Tip="Broadcaster Color" ColorChanged="TextColorPicker_ColorChanged" HorizontalAlignment="Center" IsAlphaEnabled="False" ColorSpectrumShape="Ring" />
                                    <ColorPicker Grid.Row="1" Grid.Column="3" Name="ModColorPicker" ToolTip.Tip="Moderator Color" ColorChanged="TextColorPicker_ColorChanged" HorizontalAlignment="Center" IsAlphaEnabled="False" ColorSpectrumShape="Ring" />
                                    <ColorPicker Grid.Row="1" Grid.Column="4" Name="VipColorPicker" ToolTip.Tip="VIP Color" ColorChanged="TextColorPicker_ColorChanged" HorizontalAlignment="Center" IsAlphaEnabled="False" ColorSpectrumShape="Ring" />
                                </Grid>
                            </StackPanel>

                            <Separator Background="#334155" Margin="0,5" Height="1"/>

                            <!-- ⚙️ Дополнительно -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,5,0,5">
                                <PathIcon Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.43-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" Width="16" Height="16" Foreground="#38BDF8"/>
                                <TextBlock Text="{DynamicResource CategoryExtra}" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Spacing="6" Margin="0,0,0,10">
                                <StackPanel Spacing="6">
                                    <Grid>
                                        <TextBlock Text="{DynamicResource FontSizeLabel}" FontSize="13" Foreground="#E2E8F0"/>
                                        <TextBlock Name="FontSizeValText" Text="14px" HorizontalAlignment="Right" Foreground="#94A3B8" FontSize="12"/>
                                    </Grid>
                                    <Slider Name="FontSizeSlider" Minimum="10" Maximum="32" Value="14" TickFrequency="1" IsSnapToTickEnabled="True" PropertyChanged="DesignSlider_PropertyChanged" />
                                </StackPanel>
                                
                                <StackPanel Spacing="8" Margin="0,10,0,0">
                                    <CheckBox Name="EnableGroupingCheck" Content="{DynamicResource EnableGroupingCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed"/>
                                    <CheckBox Name="HighlightMentionsCheck" Content="{DynamicResource HighlightMentionsCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                                    <CheckBox Name="HighlightFirstMessageCheck" Content="{DynamicResource HighlightFirstMessageCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                                    <CheckBox Name="HideBackgroundCheck" Content="{DynamicResource HideBackgroundCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                                    <CheckBox Name="HideBadgesCheck" Content="{DynamicResource HideBadgesCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                                    <CheckBox Name="HideBotMessagesCheck" Content="{DynamicResource HideBotMessagesCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                                    <CheckBox Name="HideModMessagesCheck" Content="{DynamicResource HideModMessagesCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                                    <CheckBox Name="HideVipMessagesCheck" Content="{DynamicResource HideVipMessagesCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                                    <CheckBox Name="EnableRoleColorsCheck" Content="{DynamicResource EnableRoleColorsCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                                    <CheckBox Name="TextOutlineCheck" Content="{DynamicResource TextOutlineCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                                    <StackPanel Margin="0,0,0,0">
                                        <CheckBox Name="EnableJokeScriptCheck" Content="{DynamicResource EnableJokeScriptCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                                        <TextBlock Text="{DynamicResource JokeScriptDescription}" FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap" Margin="25,-5,0,0" />
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" Margin="0,5,0,0">
                                        <Button Grid.Column="0" Margin="0,0,5,0" Click="EditBlacklist_Click" Background="#334155" Foreground="#E2E8F0" Padding="10,6" CornerRadius="4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                            <TextBlock Text="{DynamicResource EditBlacklistLabel}" TextTrimming="CharacterEllipsis" TextAlignment="Center" />
                                            <Button.Styles>
                                                <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                    <Setter Property="Background" Value="#475569"/>
                                                </Style>
                                            </Button.Styles>
                                        </Button>
                                        <Button Grid.Column="1" Margin="5,0,0,0" Click="EditBanPhrases_Click" Background="#334155" Foreground="#E2E8F0" Padding="10,6" CornerRadius="4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                            <TextBlock Text="{DynamicResource EditBanPhrasesLabel}" TextTrimming="CharacterEllipsis" TextAlignment="Center" />
                                            <Button.Styles>
                                                <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                                    <Setter Property="Background" Value="#475569"/>
                                                </Style>
                                            </Button.Styles>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <Separator Background="#334155" Margin="0,5" Height="1"/>

                            <!-- 😃 Эмоуты -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,5,0,5">
                                <PathIcon Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M7,9.5C7,8.7 7.7,8 8.5,8C9.3,8 10,8.7 10,9.5C10,10.3 9.3,11 8.5,11C7.7,11 7,10.3 7,9.5M12,17.5C9.7,17.5 7.8,16 7,14H17C16.2,16 14.3,17.5 12,17.5M15.5,11C14.7,11 14,10.3 14,9.5C14,8.7 14.7,8 15.5,8C16.3,8 17,8.7 17,9.5C17,10.3 16.3,11 15.5,11Z" Width="16" Height="16" Foreground="#38BDF8"/>
                                <TextBlock Text="{DynamicResource CategoryEmotes}" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Spacing="8" Margin="0,0,0,10">
                                <CheckBox Name="StreamerEmotesCheck" Content="{DynamicResource StreamerEmotesCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed"/>
                                <CheckBox Name="GlobalEmotesCheck" Content="{DynamicResource GlobalEmotesCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                                <CheckBox Name="Global7TVEmotesCheck" Content="{DynamicResource Global7TVEmotesCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                                <CheckBox Name="ShowBTTVEmotesCheck" Content="{DynamicResource ShowBTTVEmotesCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                                <CheckBox Name="ShowFFZEmotesCheck" Content="{DynamicResource ShowFFZEmotesCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed" Margin="0,-5"/>
                            </StackPanel>
                            
                            <Separator Background="#334155" Margin="0,5" Height="1"/>
                            
                            <!-- 💬 Команды чата -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,5,0,5">
                                <PathIcon Data="M20,2H4C2.9,2 2,2.9 2,4V22L6,18H20C21.1,18 22,17.1 22,16V4C22,2.9 21.1,2 20,2M11,14H9V12H11V14M11,10H9V6H11V10M15,14H13V12H15V14M15,10H13V6H15V10Z" Width="16" Height="16" Foreground="#38BDF8"/>
                                <TextBlock Text="{DynamicResource CategoryCommands}" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Spacing="8" Margin="0,0,0,10">
                                <CheckBox Name="EnableChatEffectsCheck" Content="{DynamicResource EnableChatEffectsCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed"/>
                                <TextBlock Text="{DynamicResource ChatEffectsHint}" TextWrapping="Wrap" Foreground="#94A3B8" FontSize="11" Margin="24,-4,0,0"/>
                            </StackPanel>

                            <TextBlock Text="{DynamicResource DesignHintText}" TextWrapping="Wrap" Foreground="#64748B" FontSize="12"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Live Preview Panel (WebView2) -->
            <Grid Name="PreviewPanel" Grid.Column="1" Margin="24">
                <Border Background="#1E1B4B" CornerRadius="12" BorderBrush="#334155" BorderThickness="1" ClipToBounds="True">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                            <TextBlock Text="{DynamicResource LivePreviewTitle}" Foreground="#64748B" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource LivePreviewSubtitle}" Foreground="#475569" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <v:PreviewWebView Margin="12" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Dim Overlay -->
        <Border Name="OverlayBackground" Background="#A0000000" IsVisible="False" ZIndex="10" />


        <!-- Settings Modal Card -->
        <Border Name="SettingsModal" IsVisible="False" ZIndex="11" Background="#1E293B" Padding="32" 
                CornerRadius="16" BoxShadow="0 20 40 0 #A0000000"
                HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="0,40,0,40" Width="450">
            <Grid RowDefinitions="Auto, *">
                <Grid Grid.Row="0" Margin="0,0,10,16">
                    <TextBlock Text="{DynamicResource TechnicalSettingsTitle}" FontSize="20" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center" />
                    <Button Content="✕" HorizontalAlignment="Right" Background="#334155" Foreground="#F87171" Click="CloseSettings_Click" Padding="12,8" CornerRadius="8" FontSize="16" FontWeight="Bold" Cursor="Hand" />
                </Grid>
                <ScrollViewer Grid.Row="1">
                <StackPanel Spacing="16" Margin="0,0,10,0">

                <StackPanel Spacing="6">
                    <TextBlock Text="{DynamicResource AppLanguageLabel}" FontWeight="SemiBold"/>
                    <ComboBox Name="LangComboBox" SelectedIndex="0" HorizontalAlignment="Stretch" SelectionChanged="LangComboBox_SelectionChanged">
                        <ComboBoxItem>Русский</ComboBoxItem>
                        <ComboBoxItem>English</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{DynamicResource TwitchUsernameLabel}" FontWeight="SemiBold"/>
                    <TextBox Name="UsernameTextBox" TextChanged="TextBox_TextChanged" Watermark="e.g. FHRha"/>
                    
                    <!-- Hidden Test Mode Panel -->
                    <StackPanel Name="TestModePanel" IsVisible="False" Spacing="6" Margin="0,5,0,0">
                        <Border Background="#3B82F6" CornerRadius="4" Padding="6,2">
                            <TextBlock Text="{DynamicResource TestModeActiveLabel}" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                        </Border>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Grid.Column="0" Text="{DynamicResource SimulationSpeedLabel}" FontSize="12" Foreground="#94A3B8"/>
                            <TextBlock Grid.Column="1" Name="TestSpeedValText" Text="1000" FontSize="12" Foreground="#94A3B8" FontWeight="Bold"/>
                        </Grid>
                        <Slider Name="TestSpeedSlider" Minimum="100" Maximum="3000" Value="1000" TickFrequency="100" IsSnapToTickEnabled="True" PropertyChanged="TestSpeedSlider_PropertyChanged" />
                    </StackPanel>
                </StackPanel>

                <CheckBox Name="MinimizeToTrayCheck" Content="{DynamicResource MinimizeToTrayCheck}" Checked="DesignCheckBox_Changed" Unchecked="DesignCheckBox_Changed"/>

                <StackPanel Spacing="6">
                    <TextBlock Text="{DynamicResource ServerPortLabel}" FontWeight="SemiBold"/>
                    <TextBox Name="ServerPortTextBox" Text="0" TextChanged="TextBox_TextChanged" Watermark="0 for auto-assign"/>
                    <TextBlock Text="{DynamicResource RestartRequiredHint}" FontSize="11" Foreground="#94A3B8"/>
                </StackPanel>

                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,2">
                        <TextBlock Grid.Column="0" Text="{DynamicResource CustomWorkerLabel}" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="{DynamicResource HowToCreateWorkerBtn}" Click="OpenWorkerGuide_Click" HorizontalAlignment="Right" Background="Transparent" Foreground="#3B82F6" Padding="4,0" Cursor="Hand" FontSize="12" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBox Name="CustomWorkerTextBox" TextChanged="TextBox_TextChanged" Watermark="https://..."/>
                    <TextBlock Text="{DynamicResource CustomWorkerHint}" FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Twitch Proxy Section -->
                <StackPanel Spacing="6" Margin="0,5,0,0">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,2">
                        <TextBlock Grid.Column="0" Text="Twitch Chat Proxy (Google Cloud Run)" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ToggleSwitch Grid.Column="1" Name="UseTwitchProxySwitch" IsChecked="False" Checked="ProxySettings_Changed" Unchecked="ProxySettings_Changed"/>
                    </Grid>
                    <TextBlock Text="Маршрутизировать трафик Twitch чата через прокси-сервер (помогает от блокировок и скрывает IP-адрес)." FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,-4,0,4"/>
                    
                    <StackPanel Name="ProxyListPanel" IsVisible="False" Spacing="8">
                        <Button Content="+ Добавить прокси" Click="AddProxy_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#0F172A" Foreground="#38BDF8" CornerRadius="8"/>
                        <ItemsControl Name="ProxiesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="models:CloudProxyServer">
                                    <Border Background="#0F172A" CornerRadius="8" Padding="12" Margin="0,0,0,8" BorderBrush="#334155" BorderThickness="1">
                                        <StackPanel Spacing="6">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="Bold" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="✕" Click="RemoveProxy_Click" CommandParameter="{Binding}" Background="Transparent" Foreground="#F87171" Padding="8,4" Margin="0,-8,-8,0" Cursor="Hand"/>
                                            </Grid>
                                            <TextBox Text="{Binding Url}" Watermark="wss://twichat-proxy-..." TextChanged="ProxyItem_TextChanged" FontSize="12" Padding="8,6"/>
                                            <TextBox Text="{Binding Token}" Watermark="X-Proxy-Token" TextChanged="ProxyItem_TextChanged" FontSize="12" Padding="8,6"/>
                                            <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                                                <ProgressBar Grid.Column="0" Minimum="0" Maximum="360000" Value="{Binding UsageSeconds}" Height="6" CornerRadius="3" Foreground="#10B981" Background="#1E293B" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding UsageSeconds, StringFormat='{}{0} / 360000 s'}" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="Инструкция по быстрой установке прокси..." Click="OpenProxyGuide_Click" Background="Transparent" Foreground="#3B82F6" FontSize="12" Padding="0" Cursor="Hand" HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="{DynamicResource ObsSourceUrlLabel}" FontWeight="SemiBold"/>
                    <TextBox Name="ObsUrlTextBox" IsReadOnly="True" />
                    <Button Content="{DynamicResource CopyLinkButton}" Click="CopyUrl_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <Button Content="{DynamicResource CheckForUpdatesLabel}" Click="CheckForUpdates_Click" Background="#2563EB" Foreground="White" Padding="10,6" CornerRadius="4" Margin="0,15,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontWeight="Bold">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="#1D4ED8"/>
                        </Style>
                    </Button.Styles>
                </Button>
                </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</Window>
